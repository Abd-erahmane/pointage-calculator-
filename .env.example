# Copiez ce fichier en .env et remplissez vos valeurs
# Pour la prod (Vercel), définissez ces variables dans le dashboard Vercel

# URL de connexion PostgreSQL
# Local :
# DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@127.0.0.1:5432/comptage
# Cloud Neon (recommandé pour Vercel) :
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

DATABASE_URL=

# Port local (ignoré sur Vercel)
PORT=3000
